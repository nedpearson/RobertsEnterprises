# ============================================================
# RobertsEnterprises / VowOS — Environment Variables
# Copy this file to .env (never commit .env)
# All variables marked REQUIRED must be set before the API
# will start in production (NODE_ENV=production).
# ============================================================

# ── Node ─────────────────────────────────────────────────────
NODE_ENV=production          # REQUIRED: set to "production" on Railway

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
# REQUIRED in production. Railway auto-sets this when you attach
# a Postgres plugin — just reference ${{Postgres.DATABASE_URL}}.
# Leave unset locally to use SQLite (apps/api/vowos_dev.sqlite3).

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=replace-me        # REQUIRED: run `openssl rand -hex 32` and paste here
# The API refuses to boot in production without this.
# Rotate this value to invalidate all existing sessions.

# ── Stripe (optional — stubbed until wired) ──────────────────
FRONTEND_URL=https://your-frontend.railway.app
# Used for Stripe checkout success/cancel redirect URLs.
# Defaults to http://localhost:5173 when unset.

STRIPE_SECRET_KEY=sk_live_...
# When set, POST /api/invoices/:id/checkout creates real Stripe sessions.
# Use sk_test_... for staging. Leave unset to keep the stub.

STRIPE_WEBHOOK_SECRET=whsec_...
# Needed to validate Stripe webhook signatures on POST /api/webhooks/stripe.

# ── Twilio (optional — stubbed until wired) ──────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567
# When all three are set, POST /api/follow-ups/:id/send sends real SMS.
# POST /api/webhooks/sms validates Twilio signatures.
# Leave all three unset to keep stubs (safe for dev/staging).

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=https://your-frontend.railway.app,https://yourdomain.com
# Comma-separated list of allowed origins.
# Defaults to: http://localhost:5173,https://robertsenterprises.bridgebox.ai

# ── Frontend (apps/web) ──────────────────────────────────────
VITE_API_URL=https://your-api.railway.app
# URL of the deployed API. Baked into the frontend at build time.
# Defaults to http://localhost:4000 for local dev.

# ── Seed guard ───────────────────────────────────────────────
ADMIN_SEED_SECRET=replace-me-or-leave-unset-to-disable-guard
# When set, POST /api/seed (and other seed endpoints) require the
# X-Seed-Secret header to match this value. Leave unset in local dev
# to allow seeding without a header. REQUIRED in production.

# ── Port ─────────────────────────────────────────────────────
PORT=4000
# Railway sets this automatically — only override for local dev.
