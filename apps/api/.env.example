# VowOS backend — copy to .env, never commit real .env
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/vowos   # production (pg)
JWT_SECRET=change-me-long-random-string                    # REQUIRED in production
STRIPE_SECRET_KEY=                                         # optional (mock fallback in dev)
TWILIO_ACCOUNT_SID=                                        # optional
TWILIO_AUTH_TOKEN=
CORS_ORIGIN=http://localhost:5173,https://robertsenterprises.bridgebox.ai
