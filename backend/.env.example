# VowOS Environment Configuration

# Current Node Runtime Environment (development | production)
# Development defaults to local SQLite runtime.
# Production pivots execution strictly to the attached DATABASE_URL Postgres Cloud service.
NODE_ENV=development

# Postgres Connection String
# Example: postgres://username:password@rds.amazon.com:5432/vowos_db
DATABASE_URL=postgres://user:password@localhost:5432/vowos

# Secret Key for JSON Web Token Signature
JWT_SECRET=vowos-production-secret-4050
